APP_ENV=local
APP_NAME=Fury Note API
API_V1_PREFIX=/v1

DB_HOST=127.0.0.1
DB_PORT=3303
DB_NAME=furynote
DB_USER=furynote
DB_PASSWORD=furynote

OPENAI_API_KEY=

# Path to the Firebase service-account JSON used to send comment push notifications via FCM.
# Defaults to ./furynote-firebase-adminsdk-fbsvc-c60c7a3f0c.json when omitted.
# Get this file from Firebase Console > Project settings > Service accounts > Generate new private key.
FIREBASE_CREDENTIALS_PATH=furynote-firebase-adminsdk-fbsvc-c60c7a3f0c.json

APPLE_VERIFY_URL=https://buy.itunes.apple.com/verifyReceipt
GOOGLE_PACKAGE_NAME=kr.co.lunlu.furynote

# Shared secret used to verify HMAC request signatures from the mobile app.
# Must match the HMAC_SECRET baked into mobile/env/*.json. Set a strong random
# value in production — do not keep the dev default.
APP_HMAC_SECRET=c477ae80ccc4e7d8e38ad2ab0abc1f34f451c20c084551e01638554098a6a48f
