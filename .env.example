# Fury Note root environment reference
#
# Local Docker MariaDB:
#   APP_ENV=local uses DB_PORT=3303.
#
# Non-local environments:
#   APP_ENV=production, staging, or any other value defaults to DB_PORT=3306
#   unless DB_PORT is explicitly set.

APP_ENV=local
APP_NAME=Fury Note API
API_V1_PREFIX=/v1

DB_HOST=127.0.0.1
DB_PORT=3303
DB_NAME=furynote
DB_USER=furynote
DB_PASSWORD=furynote

OPENAI_API_KEY=
FIREBASE_CREDENTIALS_PATH=
APPLE_VERIFY_URL=https://buy.itunes.apple.com/verifyReceipt
GOOGLE_PACKAGE_NAME=kr.co.lunlu.furynote
